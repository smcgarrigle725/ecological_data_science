{
  "tables": [
    {
      "TableName": "Site",
      "description": "Hub table. All sample tables reference siteid as a foreign key.",
      "KeySchema": [
        { "AttributeName": "siteid", "KeyType": "HASH" }
      ],
      "AttributeDefinitions": [
        { "AttributeName": "siteid", "AttributeType": "S" },
        { "AttributeName": "waterbody", "AttributeType": "S" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "waterbody-index",
          "KeySchema": [
            { "AttributeName": "waterbody", "KeyType": "HASH" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST",
      "SampleAttributes": {
        "siteid":               "string  — Autogenerated: Year_Site_SampleType (e.g. 2022_HarbourNorth_Animal)",
        "collection_organization": "string",
        "primarycontact":       "string",
        "year":                 "string  — Four-digit year (e.g. 2022)",
        "waterbody":            "string",
        "waterbodytype":        "string  — Freshwater | Marine | Brackish",
        "site":                 "string",
        "latitude":             "number  — Decimal degrees",
        "longitude":            "number  — Decimal degrees",
        "substrate":            "string",
        "benthicpelagic":       "string  — Benthic | Pelagic",
        "tidaldepth":           "string  — e.g. intertidal, subtidal (marine only)",
        "samplestaken":         "number",
        "sampletypes":          "string  — Animal | Sediment | Water (or combination)"
      }
    },
    {
      "TableName": "Animal",
      "description": "One record per animal (bivalve) sample. Links to Site via siteid.",
      "KeySchema": [
        { "AttributeName": "id", "KeyType": "HASH" }
      ],
      "AttributeDefinitions": [
        { "AttributeName": "id",     "AttributeType": "S" },
        { "AttributeName": "siteid", "AttributeType": "S" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "siteid-index",
          "KeySchema": [
            { "AttributeName": "siteid", "KeyType": "HASH" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST",
      "SampleAttributes": {
        "id":                      "string  — Autogenerated: Year_Site_Animal_sampleid",
        "siteid":                  "string  — Foreign key → Site",
        "sampleid":                "string  — Sample ID as given by collection group",
        "collection_organization": "string",
        "primarycontact":          "string",
        "site":                    "string",
        "year":                    "string",
        "date":                    "string  — ISO 8601 (YYYY-MM-DD)",
        "processingmethod":        "string",
        "species_common":          "string",
        "species_scientific":      "string",
        "number_animal":           "number",
        "sampleweight":            "number",
        "animallength":            "number",
        "tissuetype":              "string",
        "totalmp":                 "number",
        "fibre":                   "number",
        "fragment":                "number",
        "sphere":                  "number",
        "film":                    "number",
        "ftir_complete":           "string  — Y | N",
        "ftir_numbersent":         "number"
      }
    },
    {
      "TableName": "Sediment",
      "description": "One record per sediment sample. Links to Site via siteid.",
      "KeySchema": [
        { "AttributeName": "id", "KeyType": "HASH" }
      ],
      "AttributeDefinitions": [
        { "AttributeName": "id",     "AttributeType": "S" },
        { "AttributeName": "siteid", "AttributeType": "S" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "siteid-index",
          "KeySchema": [
            { "AttributeName": "siteid", "KeyType": "HASH" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST",
      "SampleAttributes": {
        "id":                      "string  — Autogenerated: Year_Site_Sediment_sampleid",
        "siteid":                  "string  — Foreign key → Site",
        "sampleid":                "string  — Sample ID as given by collection group",
        "collection_organization": "string",
        "primarycontact":          "string",
        "site":                    "string",
        "year":                    "string",
        "date":                    "string  — ISO 8601 (YYYY-MM-DD)",
        "processingmethod":        "string",
        "sampleweight_wwt":        "number  — Grams, wet weight",
        "totalmp":                 "number",
        "fibre":                   "number",
        "fragment":                "number",
        "sphere":                  "number",
        "film":                    "number",
        "ftir_complete":           "string  — Y | N",
        "ftir_numbersent":         "number"
      }
    },
    {
      "TableName": "Water",
      "description": "One record per water sample. Links to Site via siteid.",
      "KeySchema": [
        { "AttributeName": "id", "KeyType": "HASH" }
      ],
      "AttributeDefinitions": [
        { "AttributeName": "id",     "AttributeType": "S" },
        { "AttributeName": "siteid", "AttributeType": "S" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "siteid-index",
          "KeySchema": [
            { "AttributeName": "siteid", "KeyType": "HASH" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST",
      "SampleAttributes": {
        "id":                      "string  — Autogenerated: Year_Site_Water_sampleid",
        "siteid":                  "string  — Foreign key → Site",
        "sampleid":                "string  — Sample ID as given by collection group",
        "collection_organization": "string",
        "primarycontact":          "string",
        "site":                    "string",
        "year":                    "string",
        "date":                    "string  — ISO 8601 (YYYY-MM-DD)",
        "processingmethod":        "string",
        "samplevolume":            "number  — Litres",
        "totalmp":                 "number",
        "fibre":                   "number",
        "fragment":                "number",
        "sphere":                  "number",
        "film":                    "number",
        "ftir_complete":           "string  — Y | N",
        "ftir_numbersent":         "number"
      }
    },
    {
      "TableName": "FTIR",
      "description": "One record per MP particle processed by micro-FTIR. Links to parent sample via id. No sample_type field — originating matrix was not recorded at time of FTIR submission; matrix can be inferred from the id string structure if needed.",
      "KeySchema": [
        { "AttributeName": "mp_id", "KeyType": "HASH" }
      ],
      "AttributeDefinitions": [
        { "AttributeName": "mp_id", "AttributeType": "S" },
        { "AttributeName": "id",    "AttributeType": "S" }
      ],
      "GlobalSecondaryIndexes": [
        {
          "IndexName": "id-index",
          "KeySchema": [
            { "AttributeName": "id", "KeyType": "HASH" }
          ],
          "Projection": { "ProjectionType": "ALL" }
        }
      ],
      "BillingMode": "PAY_PER_REQUEST",
      "SampleAttributes": {
        "mp_id":                   "string  — Autogenerated: parent id + _XX (e.g. 2022_HarbourNorth_Animal_S01_03)",
        "id":                      "string  — Foreign key → Animal / Sediment / Water partition key",
        "sampleid":                "string  — Sample ID as given by collection group",
        "collection_organization": "string",
        "primarycontact":          "string",
        "date":                    "string  — ISO 8601: date sent to FTIR lab",
        "common_plastic":          "string  — Y | N",
        "ftir_primary":            "string",
        "ftir_secondary":          "string",
        "ftir_tertiary":           "string",
        "ftir_quarternary":        "string",
        "ftir_quinary":            "string",
        "cellulosic_peak":         "string  — Y | N",
        "ftir_size_microns":       "number",
        "colour":                  "string",
        "other_colour":            "string",
        "structure":               "string  — fibre | fragment | sphere | film",
        "filename":                "string  — Spectrogram file name from FTIR lab"
      }
    }
  ]
}